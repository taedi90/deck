{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/deck-workflow.schema.json",
  "title": "DeckWorkflow",
  "type": "object",
  "additionalProperties": false,
  "required": ["role", "version"],
  "not": {
    "allOf": [
      { "required": ["phases"] },
      { "required": ["steps"] }
    ]
  },
  "anyOf": [
    { "required": ["phases"] },
    { "required": ["steps"] },
    { "required": ["imports"] }
  ],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["pack", "apply"]
    },
    "version": {
      "type": "string",
      "const": "v1alpha1"
    },
    "vars": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "varImports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "imports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phase" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stepBase" }
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "anyOf": [
        { "required": ["steps"] },
        { "required": ["imports"] }
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "imports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "when": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/stepBase" }
        }
      }
    },
    "stepBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "spec"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,127}$"
        },
        "apiVersion": {
          "type": "string",
          "const": "deck/v1alpha1"
        },
        "kind": {
          "type": "string",
          "enum": [
            "CheckHost",
            "DownloadPackages",
            "DownloadK8sPackages",
            "DownloadImages",
            "DownloadFile",
            "InstallArtifacts",
            "InstallPackages",
            "WriteFile",
            "EditFile",
            "CopyFile",
            "Sysctl",
            "Modprobe",
            "Service",
            "EnsureDir",
            "Symlink",
            "InstallFile",
            "TemplateFile",
            "SystemdUnit",
            "RepoConfig",
            "PackageCache",
            "ContainerdConfig",
            "Swap",
            "KernelModule",
            "SysctlApply",
            "RunCommand",
            "WaitPath",
            "VerifyImages",
            "KubeadmInit",
            "KubeadmJoin",
            "KubeadmReset"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "when": {
          "type": "string",
          "minLength": 1
        },
        "retry": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "timeout": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$"
        },
        "register": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          }
        },
        "spec": {
          "type": "object"
        }
      }
    }
  }
}
