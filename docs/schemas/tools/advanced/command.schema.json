{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/command.schema.json",
  "title": "CommandStep",
  "description": "Escape hatch for commands that are not yet covered by typed steps.",
  "x-deck-visibility": "advanced",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "kind": {
      "const": "Command"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "sudo": {
          "type": "boolean",
          "default": false
        },
        "timeout": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$"
        }
      }
    }
  }
}
