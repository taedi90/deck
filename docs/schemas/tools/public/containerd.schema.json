{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/containerd.schema.json",
  "title": "ContainerdStep",
  "description": "Configures containerd defaults and registry host settings during apply.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "kind": {
      "const": "Containerd"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "configPath": {
          "type": "string",
          "minLength": 1
        },
        "systemdCgroup": {
          "type": "boolean"
        },
        "createDefault": {
          "type": "boolean",
          "default": true
        },
        "registryHosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "registry",
              "server",
              "host",
              "capabilities",
              "skipVerify"
            ],
            "properties": {
              "registry": {
                "type": "string",
                "minLength": 1
              },
              "server": {
                "type": "string",
                "minLength": 1
              },
              "host": {
                "type": "string",
                "minLength": 1
              },
              "capabilities": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "skipVerify": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}
