{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/repository.schema.json",
  "title": "RepositoryStep",
  "description": "Configures repository definitions on the local node.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "kind": {
      "const": "Repository"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "configure"
          ]
        },
        "format": {
          "type": "string",
          "enum": [
            "apt",
            "yum"
          ]
        },
        "path": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "pattern": "^[0-7]{4}$"
        },
        "replaceExisting": {
          "type": "boolean"
        },
        "disableExisting": {
          "type": "boolean"
        },
        "backupPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cleanupPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "refreshCache": {
          "type": "object",
          "additionalProperties": true
        },
        "repositories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "configure"
              }
            }
          },
          "then": {
            "required": [
              "repositories"
            ]
          }
        }
      ]
    }
  }
}
