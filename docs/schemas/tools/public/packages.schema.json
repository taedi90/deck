{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/packages.schema.json",
  "title": "PackagesStep",
  "description": "Installs packages on the local node.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "kind": {
      "const": "Packages"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packages"
      ],
      "properties": {
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "const": "local-repo"
            },
            "path": {
              "type": "string"
            }
          }
        },
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "restrictToRepos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excludeRepos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
