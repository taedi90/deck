{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/download-k8s-packages.schema.json",
  "title": "DownloadK8sPackagesStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1" },
    "kind": { "const": "DownloadK8sPackages" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kubernetesVersion", "components", "distro", "output"],
      "properties": {
        "kubernetesVersion": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["kubelet", "kubeadm", "kubectl"] }
        },
        "distro": {
          "type": "object",
          "additionalProperties": false,
          "required": ["family", "release", "arch"],
          "properties": {
            "family": { "type": "string", "enum": ["debian", "rhel"] },
            "release": { "type": "string" },
            "arch": { "type": "string", "enum": ["amd64", "arm64"] }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dir", "manifest"],
          "properties": {
            "dir": { "type": "string" },
            "manifest": { "type": "string" }
          }
        }
      }
    }
  }
}
