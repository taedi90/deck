{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/wait-path.schema.json",
  "title": "WaitPathStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "WaitPath" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "state"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "enum": ["exists", "absent"] },
        "nonEmpty": { "type": "boolean" },
        "type": { "type": "string", "enum": ["any", "file", "dir"] },
        "pollInterval": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
        "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": { "const": "absent" }
            },
            "required": ["state"]
          },
          "then": {
            "not": { "required": ["nonEmpty"] }
          }
        }
      ]
    }
  }
}
