{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/kubeadm-init.schema.json",
  "title": "KubeadmInitStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "KubeadmInit" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outputJoinFile"],
      "properties": {
        "mode": { "type": "string", "enum": ["stub", "real"] },
        "configFile": { "type": "string" },
        "configTemplate": { "type": "string" },
        "pullImages": { "type": "boolean" },
        "outputJoinFile": { "type": "string" },
        "kubernetesVersion": { "type": "string" },
        "advertiseAddress": { "type": "string" },
        "podNetworkCIDR": { "type": "string" },
        "criSocket": { "type": "string" },
        "ignorePreflightErrors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "extraArgs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
        "skipIfAdminConfExists": { "type": "boolean", "default": true }
      }
    }
  }
}
