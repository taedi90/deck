{
  "$id": "https://deck.local/schemas/tools/package.install.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Installs packages on the local node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "InstallPackage"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "excludeRepos": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "packages": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "restrictToRepos": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string"
            },
            "type": {
              "const": "local-repo"
            }
          },
          "required": [
            "type",
            "path"
          ],
          "type": "object"
        }
      },
      "required": [
        "packages"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "InstallPackageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
