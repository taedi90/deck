{
  "$id": "https://deck.local/schemas/tools/package.install.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Install packages on the local node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "InstallPackage"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/install-package",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "excludeRepos": {
          "description": "Repository selectors to exclude from package resolution.",
          "examples": [
            "[updates]"
          ],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "packages": {
          "description": "Package names to install.",
          "examples": [
            "[kubelet,kubeadm,kubectl]"
          ],
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "restrictToRepos": {
          "description": "Limit package manager visibility to these repository selectors.",
          "examples": [
            "[offline-kubernetes]"
          ],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "additionalProperties": false,
          "description": "Local repository source used for the installation.",
          "examples": [
            "{type:local-repo,path:/opt/deck/repos/kubernetes}"
          ],
          "properties": {
            "path": {
              "description": "Filesystem path to the pre-prepared local package repository.",
              "examples": [
                "/opt/deck/repos/kubernetes"
              ],
              "minLength": 1,
              "type": "string"
            },
            "type": {
              "const": "local-repo",
              "description": "Source type. Currently only `local-repo` is supported.",
              "examples": [
                "local-repo"
              ]
            }
          },
          "required": [
            "type",
            "path"
          ],
          "type": "object"
        }
      },
      "required": [
        "packages"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "InstallPackageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
