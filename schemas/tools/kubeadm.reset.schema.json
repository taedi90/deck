{
  "$id": "https://deck.local/schemas/tools/kubeadm.reset.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Run kubeadm reset and optional cleanup steps.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "ResetKubeadm"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/taedi90/deck/internal/stepspec/kubeadm-reset",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "cleanupContainers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "criSocket": {
          "type": "string"
        },
        "extraArgs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "force": {
          "default": false,
          "type": "boolean"
        },
        "ignoreErrors": {
          "default": false,
          "type": "boolean"
        },
        "removeFiles": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "removePaths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "reportFile": {
          "type": "string"
        },
        "reportResetReason": {
          "type": "string"
        },
        "restartRuntimeService": {
          "type": "string"
        },
        "stopKubelet": {
          "default": true,
          "type": "boolean"
        },
        "stopKubeletAfterReset": {
          "type": "boolean"
        },
        "verifyContainersAbsent": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "waitForMissingManifestsGlob": {
          "type": "string"
        },
        "waitForRuntimeReady": {
          "type": "boolean"
        },
        "waitForRuntimeService": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "ResetKubeadmStep",
  "type": "object",
  "x-deck-visibility": "public"
}
