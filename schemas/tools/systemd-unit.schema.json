{
  "$id": "https://deck.local/schemas/tools/systemd-unit.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Write a systemd unit file on the node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "WriteSystemdUnit"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/write-systemd-unit",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "content"
          ]
        },
        {
          "required": [
            "template"
          ]
        }
      ],
      "properties": {
        "content": {
          "description": "Inline unit file content written verbatim to `path`.",
          "examples": [
            "[Unit]\nDescription=kubelet"
          ],
          "type": "string"
        },
        "daemonReload": {
          "description": "Run `systemctl daemon-reload` after writing the unit file.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "mode": {
          "description": "File permissions applied to the unit file in octal notation.",
          "examples": [
            "0644"
          ],
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "description": "Destination path for the unit file on the node.",
          "examples": [
            "/etc/systemd/system/kubelet.service"
          ],
          "minLength": 1,
          "type": "string"
        },
        "template": {
          "description": "Inline multi-line unit content rendered with the current vars before writing.",
          "examples": [
            "[Service]\nEnvironment=NODE_IP={{ .vars.nodeIP }}"
          ],
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WriteSystemdUnitStep",
  "type": "object",
  "x-deck-visibility": "public"
}
