{
  "$id": "https://deck.local/schemas/tools/systemd-unit.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Writes a systemd unit file and optionally manages the related service.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "SystemdUnit"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "content"
          ]
        },
        {
          "required": [
            "contentFromTemplate"
          ]
        }
      ],
      "properties": {
        "content": {
          "type": "string"
        },
        "contentFromTemplate": {
          "type": "string"
        },
        "daemonReload": {
          "type": "boolean"
        },
        "mode": {
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "service": {
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "name": {
              "minLength": 1,
              "type": "string"
            },
            "state": {
              "enum": [
                "unchanged",
                "started",
                "stopped",
                "restarted",
                "reloaded"
              ],
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "title": "SystemdUnitStep",
  "type": "object",
  "x-deck-visibility": "public"
}
