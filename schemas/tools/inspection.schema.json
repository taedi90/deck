{
  "$id": "https://deck.local/schemas/tools/inspection.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Runs host inspection checks before prepare execution.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "Inspection"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "binaries": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "checks": {
          "items": {
            "enum": [
              "os",
              "arch",
              "kernelModules",
              "swap",
              "binaries"
            ],
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "failFast": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "checks"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "title": "InspectionStep",
  "type": "object",
  "x-deck-visibility": "public"
}
