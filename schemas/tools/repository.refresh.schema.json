{
  "$id": "https://deck.local/schemas/tools/repository.refresh.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Refresh package metadata with repo filtering.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "RefreshRepository"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/taedi90/deck/internal/stepspec/refresh-repository",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "anyOf": [
        {
          "properties": {
            "clean": {
              "const": true
            }
          },
          "required": [
            "clean"
          ]
        },
        {
          "properties": {
            "update": {
              "const": true
            }
          },
          "required": [
            "update"
          ]
        }
      ],
      "properties": {
        "clean": {
          "type": "boolean"
        },
        "excludeRepos": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "manager": {
          "enum": [
            "auto",
            "apt",
            "dnf"
          ],
          "type": "string"
        },
        "restrictToRepos": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "update": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "RefreshRepositoryStep",
  "type": "object",
  "x-deck-visibility": "public"
}
