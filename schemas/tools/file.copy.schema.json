{
  "$id": "https://deck.local/schemas/tools/file.copy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Copy a file from a declared source to a destination path.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "CopyFile"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/copy-file",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "fetch": {
          "additionalProperties": false,
          "description": "Optional transport policy when the source must be fetched first.",
          "examples": [
            "{offlineOnly:true}"
          ],
          "properties": {
            "offlineOnly": {
              "description": "Restrict fetches to offline-safe sources only.",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "sources": {
              "description": "Ordered list of source candidates tried for the fetch.",
              "examples": [
                "[{type:url,url:https://mirror.example.com/runc}]"
              ],
              "items": {
                "additionalProperties": false,
                "anyOf": [
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "url"
                    ]
                  }
                ],
                "properties": {
                  "path": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "type": {
                    "enum": [
                      "local",
                      "bundle",
                      "repo",
                      "online"
                    ],
                    "type": "string"
                  },
                  "url": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "type"
                ],
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "mode": {
          "description": "File permissions in octal notation applied after the copy completes.",
          "examples": [
            "0644"
          ],
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "description": "Destination path on the node.",
          "examples": [
            "/home/vagrant/.kube/config"
          ],
          "minLength": 1,
          "type": "string"
        },
        "source": {
          "additionalProperties": false,
          "anyOf": [
            {
              "required": [
                "url"
              ]
            },
            {
              "required": [
                "path"
              ]
            },
            {
              "required": [
                "bundle"
              ]
            }
          ],
          "description": "Structured source descriptor for the file to copy.",
          "examples": [
            "{path:/etc/kubernetes/admin.conf}"
          ],
          "properties": {
            "bundle": {
              "additionalProperties": false,
              "description": "Reference to a file already present in the bundle.",
              "examples": [
                "{root:files,path:bin/linux/amd64/runc}"
              ],
              "properties": {
                "path": {
                  "description": "Relative path within the selected bundle root.",
                  "examples": [
                    "bin/linux/amd64/runc"
                  ],
                  "minLength": 1,
                  "type": "string"
                },
                "root": {
                  "description": "Bundle root category to read from (`files`, `images`, or `packages`).",
                  "enum": [
                    "files",
                    "images",
                    "packages"
                  ],
                  "examples": [
                    "files"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "root",
                "path"
              ],
              "type": "object"
            },
            "path": {
              "description": "Local filesystem path used as the source.",
              "examples": [
                "/opt/cache/runc"
              ],
              "minLength": 1,
              "type": "string"
            },
            "sha256": {
              "description": "Expected SHA-256 checksum for the fetched or copied file.",
              "examples": [
                "abc123..."
              ],
              "pattern": "^[a-fA-F0-9]{64}$",
              "type": "string"
            },
            "url": {
              "description": "URL to fetch the file from during prepare.",
              "examples": [
                "https://mirror.example.com/runc"
              ],
              "minLength": 1,
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "source",
        "path"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "CopyFileStep",
  "type": "object",
  "x-deck-visibility": "public"
}
