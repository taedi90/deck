{
  "$id": "https://deck.local/schemas/tools/file.copy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Copies a file already present on the node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "FileCopy"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "dest": {
          "minLength": 1,
          "type": "string"
        },
        "mode": {
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "src": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "src",
        "dest"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "FileCopyStep",
  "type": "object",
  "x-deck-visibility": "public"
}
