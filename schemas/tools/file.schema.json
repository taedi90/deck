{
  "$id": "https://deck.local/schemas/tools/file.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Manages file operations through action-specific modes.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "File"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "download"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "source",
              "output"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "install"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "content"
                ]
              },
              {
                "required": [
                  "contentFromTemplate"
                ]
              }
            ],
            "required": [
              "path"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "copy"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "src",
              "dest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "edit"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "path",
              "edits"
            ]
          }
        }
      ],
      "properties": {
        "action": {
          "enum": [
            "download",
            "install",
            "copy",
            "edit"
          ],
          "type": "string"
        },
        "backup": {
          "type": "boolean"
        },
        "content": {
          "type": "string"
        },
        "contentFromTemplate": {
          "type": "string"
        },
        "dest": {
          "type": "string"
        },
        "edits": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "match": {
                "type": "string"
              },
              "op": {
                "type": "string"
              },
              "with": {
                "type": "string"
              }
            },
            "required": [
              "match"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "fetch": {
          "type": "object"
        },
        "group": {
          "minLength": 1,
          "type": "string"
        },
        "mode": {
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "output": {
          "additionalProperties": false,
          "properties": {
            "chmod": {
              "pattern": "^[0-7]{4}$",
              "type": "string"
            },
            "path": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "path"
          ],
          "type": "object"
        },
        "owner": {
          "minLength": 1,
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "source": {
          "additionalProperties": false,
          "anyOf": [
            {
              "required": [
                "url"
              ]
            },
            {
              "required": [
                "path"
              ]
            },
            {
              "required": [
                "bundle"
              ]
            }
          ],
          "properties": {
            "bundle": {
              "additionalProperties": false,
              "properties": {
                "path": {
                  "minLength": 1,
                  "type": "string"
                },
                "root": {
                  "enum": [
                    "files",
                    "images",
                    "packages"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "root",
                "path"
              ],
              "type": "object"
            },
            "path": {
              "minLength": 1,
              "type": "string"
            },
            "sha256": {
              "pattern": "^[a-fA-F0-9]{64}$",
              "type": "string"
            },
            "url": {
              "minLength": 1,
              "type": "string"
            }
          },
          "type": "object"
        },
        "src": {
          "type": "string"
        }
      },
      "required": [],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "title": "FileStep",
  "type": "object",
  "x-deck-visibility": "public"
}
