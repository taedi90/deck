{
  "$id": "https://deck.local/schemas/tools/kubeadm.init.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Run kubeadm init and write the join command to a file.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "InitKubeadm"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/taedi90/deck/internal/stepspec/kubeadm-init",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "advertiseAddress": {
          "type": "string"
        },
        "configFile": {
          "type": "string"
        },
        "configTemplate": {
          "type": "string"
        },
        "criSocket": {
          "type": "string"
        },
        "extraArgs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ignorePreflightErrors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kubernetesVersion": {
          "type": "string"
        },
        "outputJoinFile": {
          "minLength": 1,
          "type": "string"
        },
        "podNetworkCIDR": {
          "type": "string"
        },
        "skipIfAdminConfExists": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "outputJoinFile"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "InitKubeadmStep",
  "type": "object",
  "x-deck-visibility": "public"
}
