{
  "$id": "https://deck.local/schemas/tools/repository.configure.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Configures repository definitions on the local node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "ConfigureRepository"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "backupPaths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cleanupPaths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "disableExisting": {
          "type": "boolean"
        },
        "format": {
          "enum": [
            "auto",
            "apt",
            "yum"
          ],
          "type": "string"
        },
        "mode": {
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "replaceExisting": {
          "type": "boolean"
        },
        "repositories": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "repositories"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "ConfigureRepositoryStep",
  "type": "object",
  "x-deck-visibility": "public"
}
