{
  "$id": "https://deck.local/schemas/tools/repository.configure.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Write deb or rpm repository definitions.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "ConfigureRepository"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/taedi90/deck/internal/stepspec/configure-repository",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backupPaths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cleanupPaths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "disableExisting": {
          "type": "boolean"
        },
        "format": {
          "enum": [
            "auto",
            "deb",
            "rpm"
          ],
          "type": "string"
        },
        "mode": {
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "replaceExisting": {
          "type": "boolean"
        },
        "repositories": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "baseurl": {
                "minLength": 1,
                "type": "string"
              },
              "component": {
                "minLength": 1,
                "type": "string"
              },
              "enabled": {
                "type": "boolean"
              },
              "extra": {
                "additionalProperties": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "integer"
                    },
                    {
                      "type": "number"
                    }
                  ]
                },
                "type": "object"
              },
              "gpgcheck": {
                "type": "boolean"
              },
              "gpgkey": {
                "minLength": 1,
                "type": "string"
              },
              "id": {
                "minLength": 1,
                "type": "string"
              },
              "name": {
                "minLength": 1,
                "type": "string"
              },
              "suite": {
                "minLength": 1,
                "type": "string"
              },
              "trusted": {
                "type": "boolean"
              },
              "type": {
                "enum": [
                  "deb",
                  "deb-src"
                ],
                "type": "string"
              }
            },
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "repositories"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "ConfigureRepositoryStep",
  "type": "object",
  "x-deck-visibility": "public"
}
