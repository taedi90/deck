{
  "$id": "https://deck.local/schemas/tools/containerd.config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Write the containerd config file on the node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "WriteContainerdConfig"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/write-containerd-config",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "createDefault": {
          "default": true,
          "description": "Generate a base config with `containerd config default` when the file does not exist.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "path": {
          "description": "Destination path for the generated `config.toml`.",
          "examples": [
            "/etc/containerd/config.toml"
          ],
          "minLength": 1,
          "type": "string"
        },
        "rawSettings": {
          "description": "Ordered containerd config edits.",
          "examples": [
            "[{op:set,rawPath:plugins.\"io.containerd.grpc.v1.cri\".registry.config_path,value:/etc/containerd/certs.d}]"
          ],
          "items": {
            "additionalProperties": false,
            "oneOf": [
              {
                "required": [
                  "key"
                ]
              },
              {
                "required": [
                  "rawPath"
                ]
              }
            ],
            "properties": {
              "key": {
                "minLength": 1,
                "type": "string"
              },
              "op": {
                "enum": [
                  "set",
                  "delete",
                  "appendUnique",
                  "replaceList"
                ],
                "type": "string"
              },
              "rawPath": {
                "minLength": 1,
                "type": "string"
              },
              "value": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "integer"
                  },
                  {
                    "items": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "minItems": 1,
                    "type": "array"
                  },
                  {
                    "type": "object"
                  }
                ]
              }
            },
            "required": [
              "op"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "versionPolicy": {
          "description": "How the step chooses or enforces the containerd config version.",
          "enum": [
            "preserve",
            "require-v1",
            "require-v2",
            "require-v3"
          ],
          "examples": [
            "require-v3"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WriteContainerdConfigStep",
  "type": "object",
  "x-deck-visibility": "public"
}
