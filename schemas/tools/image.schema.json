{
  "$id": "https://deck.local/schemas/tools/image.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Checks image-related state through action-specific modes.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "Image"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "download"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "images"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "present"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "images"
            ]
          }
        }
      ],
      "properties": {
        "action": {
          "enum": [
            "download",
            "present"
          ],
          "type": "string"
        },
        "backend": {
          "additionalProperties": true,
          "type": "object"
        },
        "command": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "images": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "output": {
          "additionalProperties": true,
          "type": "object"
        },
        "runtime": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "images"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "title": "ImageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
