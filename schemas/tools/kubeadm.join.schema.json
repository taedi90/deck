{
  "$id": "https://deck.local/schemas/tools/kubeadm.join.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Run kubeadm join for a worker or additional control-plane node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "JoinKubeadm"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/kubeadm-join",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "joinFile"
          ]
        },
        {
          "required": [
            "configFile"
          ]
        }
      ],
      "properties": {
        "asControlPlane": {
          "default": false,
          "description": "Join as an additional control-plane member instead of a worker.",
          "examples": [
            "false"
          ],
          "type": "boolean"
        },
        "configFile": {
          "description": "Path to an explicit kubeadm join config file.",
          "examples": [
            "/tmp/deck/kubeadm-join.yaml"
          ],
          "minLength": 1,
          "type": "string"
        },
        "extraArgs": {
          "description": "Additional flags passed directly to kubeadm join.",
          "examples": [
            "[--skip-phases=preflight]"
          ],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "joinFile": {
          "description": "Path to the join command file produced by a prior init run.",
          "examples": [
            "/tmp/deck/join.txt"
          ],
          "minLength": 1,
          "type": "string"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "JoinKubeadmStep",
  "type": "object",
  "x-deck-visibility": "public"
}
