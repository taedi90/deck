{
  "$id": "https://deck.local/schemas/tools/file.edit.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Edit an existing file in place using ordered match rules.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "EditFile"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/edit-file",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backup": {
          "description": "Create a `.bak` copy before overwriting the original file.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "edits": {
          "description": "Ordered match/replace rules applied sequentially.",
          "examples": [
            "[{match:SystemdCgroup = false,replaceWith:SystemdCgroup = true}]"
          ],
          "items": {
            "additionalProperties": false,
            "properties": {
              "match": {
                "type": "string"
              },
              "op": {
                "enum": [
                  "replace",
                  "append"
                ],
                "type": "string"
              },
              "replaceWith": {
                "type": "string"
              }
            },
            "required": [
              "match"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "mode": {
          "description": "File permissions in octal notation applied after the edit completes.",
          "examples": [
            "0644"
          ],
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "description": "File path to edit in place.",
          "examples": [
            "/etc/containerd/config.toml"
          ],
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "path",
        "edits"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "EditFileStep",
  "type": "object",
  "x-deck-visibility": "public"
}
