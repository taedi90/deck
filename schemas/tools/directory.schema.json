{
  "$id": "https://deck.local/schemas/tools/directory.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Ensures a directory exists on the local node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "Directory"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "title": "DirectoryStep",
  "type": "object",
  "x-deck-visibility": "public"
}
