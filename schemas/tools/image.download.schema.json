{
  "$id": "https://deck.local/schemas/tools/image.download.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Download container images into prepared bundle storage.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "DownloadImage"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/download-image",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "auth": {
          "description": "Optional registry authentication entries used during download.",
          "examples": [
            "[{registry:registry.example.com,basic:{username:robot,password:${REGISTRY_PASSWORD}}}]"
          ],
          "items": {
            "additionalProperties": false,
            "properties": {
              "basic": {
                "additionalProperties": false,
                "properties": {
                  "password": {
                    "type": "string"
                  },
                  "username": {
                    "type": "string"
                  }
                },
                "required": [
                  "username",
                  "password"
                ],
                "type": "object"
              },
              "registry": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "registry",
              "basic"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "backend": {
          "additionalProperties": false,
          "description": "Backend-specific download settings.",
          "examples": [
            "{engine:go-containerregistry}"
          ],
          "properties": {
            "engine": {
              "description": "Image download engine implementation.",
              "enum": [
                "go-containerregistry"
              ],
              "examples": [
                "go-containerregistry"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "images": {
          "description": "Fully qualified image references to download.",
          "examples": [
            "[registry.k8s.io/pause:3.9]"
          ],
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "outputDir": {
          "description": "Optional bundle-relative directory for per-image tar archives.",
          "examples": [
            "images/control-plane"
          ],
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "images"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "DownloadImageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
