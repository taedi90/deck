{
  "$id": "https://deck.local/schemas/tools/kernel-module.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Load and persist kernel modules.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "KernelModule"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/taedi90/deck/internal/stepspec/kernel-module",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "oneOf": [
        {
          "not": {
            "required": [
              "names"
            ]
          },
          "required": [
            "name"
          ]
        },
        {
          "not": {
            "required": [
              "name"
            ]
          },
          "required": [
            "names"
          ]
        }
      ],
      "properties": {
        "load": {
          "default": true,
          "type": "boolean"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "names": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "persist": {
          "default": true,
          "type": "boolean"
        },
        "persistFile": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "KernelModuleStep",
  "type": "object",
  "x-deck-visibility": "public"
}
