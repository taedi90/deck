{
  "$id": "https://deck.local/schemas/tools/sysctl.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Write and optionally apply sysctl values.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "Sysctl"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/sysctl",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "apply": {
          "default": false,
          "description": "Run `sysctl -p \u003cwriteFile\u003e` after writing.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "values": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "description": "Map of sysctl key-value pairs to write.",
          "examples": [
            "{net.ipv4.ip_forward:1,net.bridge.bridge-nf-call-iptables:1}"
          ],
          "minProperties": 1,
          "type": "object"
        },
        "writeFile": {
          "description": "Path to the sysctl file written with the given values.",
          "examples": [
            "/etc/sysctl.d/99-k8s.conf"
          ],
          "type": "string"
        }
      },
      "required": [
        "values",
        "writeFile"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "SysctlStep",
  "type": "object",
  "x-deck-visibility": "public"
}
