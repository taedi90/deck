{
  "$id": "https://deck.local/schemas/tools/packages.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Installs packages on the local node.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "Packages"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "download"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "packages"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "install"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "packages"
            ]
          }
        }
      ],
      "properties": {
        "action": {
          "enum": [
            "download",
            "install"
          ],
          "type": "string"
        },
        "backend": {
          "additionalProperties": true,
          "type": "object"
        },
        "distro": {
          "additionalProperties": true,
          "type": "object"
        },
        "excludeRepos": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "output": {
          "additionalProperties": false,
          "properties": {
            "dir": {
              "minLength": 1,
              "type": "string"
            }
          },
          "type": "object"
        },
        "packages": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "repo": {
          "additionalProperties": true,
          "properties": {
            "modules": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "stream": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "stream"
                ],
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "restrictToRepos": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string"
            },
            "type": {
              "const": "local-repo"
            }
          },
          "required": [
            "type",
            "path"
          ],
          "type": "object"
        }
      },
      "required": [
        "action",
        "packages"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "title": "PackagesStep",
  "type": "object",
  "x-deck-visibility": "public"
}
