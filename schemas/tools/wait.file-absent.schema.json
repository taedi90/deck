{
  "$id": "https://deck.local/schemas/tools/wait.file-absent.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Wait until a file or directory is absent.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "WaitForMissingFile"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/wait",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "oneOf": [
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "paths"
                ]
              },
              {
                "required": [
                  "glob"
                ]
              }
            ]
          },
          "required": [
            "path"
          ]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "path"
                ]
              },
              {
                "required": [
                  "glob"
                ]
              }
            ]
          },
          "required": [
            "paths"
          ]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "path"
                ]
              },
              {
                "required": [
                  "paths"
                ]
              }
            ]
          },
          "required": [
            "glob"
          ]
        }
      ],
      "properties": {
        "glob": {
          "description": "Glob pattern that must resolve to zero matches before the step succeeds.",
          "examples": [
            "/etc/kubernetes/manifests/*.yaml"
          ],
          "minLength": 1,
          "type": "string"
        },
        "initialDelay": {
          "description": "Duration to wait before the first poll attempt.",
          "examples": [
            "1s"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "interval": {
          "description": "Duration between poll attempts.",
          "examples": [
            "2s"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "path": {
          "description": "Filesystem path to check.",
          "examples": [
            "/etc/kubernetes/admin.conf"
          ],
          "minLength": 1,
          "type": "string"
        },
        "paths": {
          "description": "List of paths that must all be absent before the step succeeds.",
          "examples": [
            "[/etc/kubernetes/manifests/a.yaml,/etc/kubernetes/manifests/b.yaml]"
          ],
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "pollInterval": {
          "description": "Deprecated alias for `interval`. Prefer `interval`.",
          "examples": [
            "2s"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "timeout": {
          "description": "Maximum total duration to wait before the step fails.",
          "examples": [
            "5m"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "type": {
          "description": "Filesystem entry type restriction for path checks.",
          "enum": [
            "any",
            "file",
            "dir"
          ],
          "examples": [
            "file"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WaitForMissingFileStep",
  "type": "object",
  "x-deck-visibility": "public"
}
