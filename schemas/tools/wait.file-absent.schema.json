{
  "$id": "https://deck.local/schemas/tools/wait.file-absent.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Wait until a file or directory is absent.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "WaitForMissingFile"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/taedi90/deck/internal/stepspec/wait",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "oneOf": [
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "paths"
                ]
              },
              {
                "required": [
                  "glob"
                ]
              }
            ]
          },
          "required": [
            "path"
          ]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "path"
                ]
              },
              {
                "required": [
                  "glob"
                ]
              }
            ]
          },
          "required": [
            "paths"
          ]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "path"
                ]
              },
              {
                "required": [
                  "paths"
                ]
              }
            ]
          },
          "required": [
            "glob"
          ]
        }
      ],
      "properties": {
        "glob": {
          "minLength": 1,
          "type": "string"
        },
        "initialDelay": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "interval": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "paths": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "pollInterval": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "timeout": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "type": {
          "enum": [
            "any",
            "file",
            "dir"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WaitForMissingFileStep",
  "type": "object",
  "x-deck-visibility": "public"
}
