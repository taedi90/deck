{
  "$id": "https://deck.local/schemas/tools/wait.tcp-port-closed.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Wait until a TCP port closes.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "WaitForMissingTCPPort"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/wait",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "address": {
          "description": "Host or IP address for TCP port checks.",
          "examples": [
            "127.0.0.1"
          ],
          "minLength": 1,
          "type": "string"
        },
        "initialDelay": {
          "description": "Duration to wait before the first poll attempt.",
          "examples": [
            "1s"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "interval": {
          "description": "Duration between poll attempts.",
          "examples": [
            "2s"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "pollInterval": {
          "description": "Deprecated alias for `interval`. Prefer `interval`.",
          "examples": [
            "2s"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "port": {
          "description": "TCP port number to check.",
          "examples": [
            "6443"
          ],
          "minLength": 1,
          "type": "string"
        },
        "timeout": {
          "description": "Maximum total duration to wait before the step fails.",
          "examples": [
            "5m"
          ],
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        }
      },
      "required": [
        "port"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WaitForMissingTCPPortStep",
  "type": "object",
  "x-deck-visibility": "public"
}
