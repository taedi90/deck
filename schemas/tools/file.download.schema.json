{
  "$id": "https://deck.local/schemas/tools/file.download.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Download a file into prepared bundle storage.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "DownloadFile"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/download-file",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "source"
          ]
        },
        {
          "required": [
            "items"
          ]
        }
      ],
      "properties": {
        "fetch": {
          "additionalProperties": false,
          "description": "Optional transport policy for the download.",
          "examples": [
            "{offlineOnly:true}"
          ],
          "properties": {
            "offlineOnly": {
              "description": "Restrict fetches to offline-safe sources only.",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "sources": {
              "description": "Ordered list of source candidates tried for the fetch.",
              "examples": [
                "[{type:url,url:https://mirror.example.com/runc}]"
              ],
              "items": {
                "additionalProperties": false,
                "anyOf": [
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "url"
                    ]
                  }
                ],
                "properties": {
                  "path": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "type": {
                    "enum": [
                      "local",
                      "bundle",
                      "repo",
                      "online"
                    ],
                    "type": "string"
                  },
                  "url": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "type"
                ],
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "items": {
          "description": "Optional list form for batching multiple download items in one step.",
          "examples": [
            "[{source:{url:https://mirror.example.com/runc},outputPath:files/bin/runc,mode:0755}]"
          ],
          "items": {
            "additionalProperties": false,
            "properties": {
              "fetch": {
                "additionalProperties": false,
                "properties": {
                  "offlineOnly": {
                    "type": "boolean"
                  },
                  "sources": {
                    "items": {
                      "additionalProperties": false,
                      "anyOf": [
                        {
                          "required": [
                            "path"
                          ]
                        },
                        {
                          "required": [
                            "url"
                          ]
                        }
                      ],
                      "properties": {
                        "path": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "type": {
                          "enum": [
                            "local",
                            "bundle",
                            "repo",
                            "online"
                          ],
                          "type": "string"
                        },
                        "url": {
                          "minLength": 1,
                          "type": "string"
                        }
                      },
                      "required": [
                        "type"
                      ],
                      "type": "object"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "mode": {
                "type": "string"
              },
              "outputPath": {
                "type": "string"
              },
              "source": {
                "additionalProperties": false,
                "anyOf": [
                  {
                    "required": [
                      "url"
                    ]
                  },
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "bundle"
                    ]
                  }
                ],
                "properties": {
                  "bundle": {
                    "additionalProperties": false,
                    "properties": {
                      "path": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "root": {
                        "enum": [
                          "files",
                          "images",
                          "packages"
                        ],
                        "type": "string"
                      }
                    },
                    "required": [
                      "root",
                      "path"
                    ],
                    "type": "object"
                  },
                  "path": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "sha256": {
                    "pattern": "^[a-fA-F0-9]{64}$",
                    "type": "string"
                  },
                  "url": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            },
            "required": [
              "source"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "mode": {
          "description": "File permissions in octal notation applied after the download completes.",
          "examples": [
            "0755"
          ],
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "outputPath": {
          "description": "Bundle-relative output path for the downloaded artifact.",
          "examples": [
            "files/bin/runc"
          ],
          "minLength": 1,
          "type": "string"
        },
        "source": {
          "additionalProperties": false,
          "anyOf": [
            {
              "required": [
                "url"
              ]
            },
            {
              "required": [
                "path"
              ]
            },
            {
              "required": [
                "bundle"
              ]
            }
          ],
          "description": "Structured source descriptor for the download.",
          "examples": [
            "{url:https://mirror.example.com/runc,sha256:abc123...}"
          ],
          "properties": {
            "bundle": {
              "additionalProperties": false,
              "description": "Reference to a file already present in the bundle.",
              "examples": [
                "{root:files,path:bin/linux/amd64/runc}"
              ],
              "properties": {
                "path": {
                  "description": "Relative path within the selected bundle root.",
                  "examples": [
                    "bin/linux/amd64/runc"
                  ],
                  "minLength": 1,
                  "type": "string"
                },
                "root": {
                  "description": "Bundle root category to read from (`files`, `images`, or `packages`).",
                  "enum": [
                    "files",
                    "images",
                    "packages"
                  ],
                  "examples": [
                    "files"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "root",
                "path"
              ],
              "type": "object"
            },
            "path": {
              "description": "Local filesystem path used as the source.",
              "examples": [
                "/opt/cache/runc"
              ],
              "minLength": 1,
              "type": "string"
            },
            "sha256": {
              "description": "Expected SHA-256 checksum for the fetched or copied file.",
              "examples": [
                "abc123..."
              ],
              "pattern": "^[a-fA-F0-9]{64}$",
              "type": "string"
            },
            "url": {
              "description": "URL to fetch the file from during prepare.",
              "examples": [
                "https://mirror.example.com/runc"
              ],
              "minLength": 1,
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "DownloadFileStep",
  "type": "object",
  "x-deck-visibility": "public"
}
