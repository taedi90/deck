{
  "$id": "https://deck.local/schemas/tools/wait.tcp-port-open.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Wait until a TCP port opens.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "WaitForTCPPort"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/taedi90/deck/internal/stepspec/wait",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "address": {
          "minLength": 1,
          "type": "string"
        },
        "initialDelay": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "interval": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "pollInterval": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "port": {
          "minLength": 1,
          "type": "string"
        },
        "timeout": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        }
      },
      "required": [
        "port"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WaitForTCPPortStep",
  "type": "object",
  "x-deck-visibility": "public"
}
