{
  "$id": "https://deck.local/schemas/tools/file.edit-toml.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Edit a TOML file in place using structured path operations.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "EditTOML"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/edit-toml",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "createIfMissing": {
          "default": false,
          "description": "Create a new empty TOML document when the file does not exist.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "edits": {
          "description": "Ordered list of structured edits applied sequentially.",
          "examples": [
            "[{op:set,rawPath:plugins.\"io.containerd.grpc.v1.cri\".registry.config_path,value:/etc/containerd/certs.d}]"
          ],
          "items": {
            "additionalProperties": false,
            "properties": {
              "op": {
                "enum": [
                  "set",
                  "delete",
                  "appendUnique",
                  "replaceList"
                ],
                "type": "string"
              },
              "rawPath": {
                "minLength": 1,
                "type": "string"
              },
              "value": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "integer"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "items": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "minItems": 1,
                    "type": "array"
                  },
                  {
                    "type": "array"
                  },
                  {
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "op",
              "rawPath"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "mode": {
          "description": "Optional file permissions to apply after the edit completes.",
          "examples": [
            "0644"
          ],
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "path": {
          "description": "TOML file path to edit in place.",
          "examples": [
            "/etc/containerd/config.toml"
          ],
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "path",
        "edits"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "EditTOMLStep",
  "type": "object",
  "x-deck-visibility": "public"
}
