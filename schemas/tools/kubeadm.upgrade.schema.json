{
  "$id": "https://deck.local/schemas/tools/kubeadm.upgrade.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Run kubeadm upgrade apply and optional kubelet restart.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "UpgradeKubeadm"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/kubeadm-upgrade",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "extraArgs": {
          "description": "Additional flags passed directly to kubeadm upgrade.",
          "examples": [
            "[--allow-experimental-upgrades]"
          ],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ignorePreflightErrors": {
          "description": "Preflight checks to suppress during upgrade.",
          "examples": [
            "[Swap]"
          ],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kubeletService": {
          "description": "Service name restarted after a successful upgrade.",
          "examples": [
            "kubelet"
          ],
          "minLength": 1,
          "type": "string"
        },
        "kubernetesVersion": {
          "description": "Kubernetes version string passed to kubeadm upgrade.",
          "examples": [
            "v1.31.0"
          ],
          "minLength": 1,
          "type": "string"
        },
        "restartKubelet": {
          "default": true,
          "description": "Restart kubelet after a successful upgrade.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        }
      },
      "required": [
        "kubernetesVersion"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "UpgradeKubeadmStep",
  "type": "object",
  "x-deck-visibility": "public"
}
