{
  "$id": "https://deck.local/schemas/tools/kubeadm.upgrade.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Runs kubeadm upgrade apply and optionally restarts kubelet.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "UpgradeKubeadm"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "extraArgs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ignorePreflightErrors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kubeletService": {
          "minLength": 1,
          "type": "string"
        },
        "kubernetesVersion": {
          "minLength": 1,
          "type": "string"
        },
        "restartKubelet": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "kubernetesVersion"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "UpgradeKubeadmStep",
  "type": "object",
  "x-deck-visibility": "public"
}
