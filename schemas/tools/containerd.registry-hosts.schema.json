{
  "$id": "https://deck.local/schemas/tools/containerd.registry-hosts.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Writes containerd registry host configuration for mirrors and trust policy.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "WriteContainerdRegistryHosts"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "registryHosts": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "capabilities": {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "minItems": 1,
                "type": "array"
              },
              "host": {
                "minLength": 1,
                "type": "string"
              },
              "registry": {
                "minLength": 1,
                "type": "string"
              },
              "server": {
                "minLength": 1,
                "type": "string"
              },
              "skipVerify": {
                "type": "boolean"
              }
            },
            "required": [
              "registry",
              "server",
              "host",
              "capabilities",
              "skipVerify"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "path",
        "registryHosts"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WriteContainerdRegistryHostsStep",
  "type": "object",
  "x-deck-visibility": "public"
}
