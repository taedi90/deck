{
  "$id": "https://deck.local/schemas/tools/package.download.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Download packages into prepared bundle storage.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "DownloadPackage"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/download-package",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "additionalProperties": false,
          "description": "Container-based download backend configuration.",
          "examples": [
            "{mode:container,runtime:docker,image:rockylinux:9}"
          ],
          "properties": {
            "image": {
              "description": "Container image used for package resolution in download mode.",
              "examples": [
                "rockylinux:9"
              ],
              "minLength": 1,
              "type": "string"
            },
            "mode": {
              "description": "Download backend mode.",
              "enum": [
                "container"
              ],
              "examples": [
                "container"
              ],
              "type": "string"
            },
            "runtime": {
              "description": "Preferred container runtime for the download helper container.",
              "enum": [
                "auto",
                "docker",
                "podman"
              ],
              "examples": [
                "docker"
              ],
              "type": "string"
            }
          },
          "required": [
            "mode",
            "image"
          ],
          "type": "object"
        },
        "distro": {
          "additionalProperties": false,
          "description": "Target distribution hint used to select resolver behavior.",
          "examples": [
            "{family:rhel,release:rocky9}"
          ],
          "properties": {
            "family": {
              "description": "Distribution family used to resolve package tooling.",
              "examples": [
                "rhel"
              ],
              "minLength": 1,
              "type": "string"
            },
            "release": {
              "description": "Distribution release used for resolver and repo layout selection.",
              "examples": [
                "rocky9"
              ],
              "minLength": 1,
              "type": "string"
            }
          },
          "type": "object"
        },
        "outputDir": {
          "description": "Optional bundle-relative output directory for downloaded package artifacts.",
          "examples": [
            "packages/kubernetes"
          ],
          "minLength": 1,
          "type": "string"
        },
        "packages": {
          "description": "Package names to download.",
          "examples": [
            "[kubelet,kubeadm,kubectl]"
          ],
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "repo": {
          "additionalProperties": false,
          "description": "Repository settings applied before download.",
          "examples": [
            "{type:rpm,modules:[{name:container-tools,stream:4.0}]}"
          ],
          "properties": {
            "generate": {
              "description": "Generate repository metadata after collecting packages.",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "modules": {
              "description": "RPM module streams to enable before resolving downloads.",
              "examples": [
                "[{name:container-tools,stream:4.0}]"
              ],
              "items": {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "stream": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "stream"
                ],
                "type": "object"
              },
              "type": "array"
            },
            "pkgsDir": {
              "description": "Subdirectory under the generated repo root where packages are written.",
              "examples": [
                "pkgs"
              ],
              "minLength": 1,
              "type": "string"
            },
            "type": {
              "description": "Repository output type for download repo mode.",
              "enum": [
                "deb-flat",
                "rpm"
              ],
              "examples": [
                "rpm"
              ],
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "packages"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "DownloadPackageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
