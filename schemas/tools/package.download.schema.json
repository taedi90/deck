{
  "$id": "https://deck.local/schemas/tools/package.download.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Downloads packages into bundle output storage.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "DownloadPackage"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "backend": {
          "additionalProperties": false,
          "properties": {
            "image": {
              "minLength": 1,
              "type": "string"
            },
            "mode": {
              "enum": [
                "container"
              ],
              "type": "string"
            },
            "runtime": {
              "enum": [
                "auto",
                "docker",
                "podman"
              ],
              "type": "string"
            }
          },
          "required": [
            "mode",
            "image"
          ],
          "type": "object"
        },
        "distro": {
          "additionalProperties": true,
          "type": "object"
        },
        "outputDir": {
          "minLength": 1,
          "type": "string"
        },
        "packages": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "repo": {
          "additionalProperties": false,
          "properties": {
            "generate": {
              "type": "boolean"
            },
            "modules": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "stream": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "stream"
                ],
                "type": "object"
              },
              "type": "array"
            },
            "pkgsDir": {
              "minLength": 1,
              "type": "string"
            },
            "type": {
              "enum": [
                "apt-flat",
                "yum"
              ],
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        }
      },
      "required": [
        "packages"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "DownloadPackageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
