{
  "$id": "https://deck.local/schemas/tools/symlink.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Create or replace a symbolic link.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "CreateSymlink"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/create-symlink",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "createParent": {
          "default": false,
          "description": "Create parent directories for `path` if needed.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "force": {
          "default": false,
          "description": "Remove an existing file or link at `path` before creating the new link.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "ignoreMissingTarget": {
          "default": false,
          "description": "Treat a missing target as a no-op instead of an error.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "path": {
          "description": "Path where the symbolic link will be created.",
          "examples": [
            "/usr/bin/runc"
          ],
          "minLength": 1,
          "type": "string"
        },
        "requireTarget": {
          "default": false,
          "description": "Fail if `target` does not exist when the link is created.",
          "examples": [
            "true"
          ],
          "type": "boolean"
        },
        "target": {
          "description": "Path that the symbolic link points to.",
          "examples": [
            "/usr/local/sbin/runc"
          ],
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "path",
        "target"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "CreateSymlinkStep",
  "type": "object",
  "x-deck-visibility": "public"
}
