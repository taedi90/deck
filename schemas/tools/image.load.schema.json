{
  "$id": "https://deck.local/schemas/tools/image.load.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Load prepared image archives into the local container runtime.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "LoadImage"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/load-image",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "command": {
          "description": "Optional runtime command override.",
          "examples": [
            "[ctr,-n,k8s.io,images,import,{archive}]"
          ],
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "images": {
          "description": "Image references to load from the prepared archives.",
          "examples": [
            "[registry.k8s.io/kube-apiserver:v1.30.1]"
          ],
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "runtime": {
          "description": "Runtime loader to use for imports.",
          "enum": [
            "auto",
            "ctr",
            "docker",
            "podman"
          ],
          "examples": [
            "ctr"
          ],
          "type": "string"
        },
        "sourceDir": {
          "description": "Directory containing prepared image archives.",
          "examples": [
            "images/control-plane"
          ],
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "images"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "LoadImageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
