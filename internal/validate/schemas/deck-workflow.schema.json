{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/deck-workflow.schema.json",
  "title": "DeckWorkflow",
  "type": "object",
  "additionalProperties": false,
  "required": ["role", "version"],
  "not": {
    "allOf": [
      { "required": ["phases"] },
      { "required": ["steps"] }
    ]
  },
  "anyOf": [
    { "required": ["artifacts"] },
    { "required": ["phases"] },
    { "required": ["steps"] },
    { "required": ["imports"] }
  ],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["prepare", "apply"]
    },
    "version": {
      "type": "string",
      "const": "v1alpha1"
    },
    "vars": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "artifacts": {
      "description": "Declarative prepare artifact inventory. Prefer this over legacy prepare download steps in new role: prepare workflows.",
      "$ref": "#/$defs/artifacts"
    },
    "varImports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "imports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phase" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stepBase" }
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "anyOf": [
        { "required": ["steps"] },
        { "required": ["imports"] }
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "imports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "when": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/stepBase" }
        }
      }
    },
    "artifactTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "osFamily": { "type": "string", "minLength": 1 },
        "release": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 }
      }
    },
    "artifactFileItem": {
      "description": "One file artifact to place under the bundle files/ root.",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "output"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "minLength": 1 }
          },
          "oneOf": [
            { "required": ["url"] },
            { "required": ["path"] }
          ]
        },
        "output": {
          "description": "Bundle file output. path is relative to the files/ root and must not start with files/.",
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "mode": { "type": "string", "pattern": "^[0-7]{4}$" }
          }
        },
        "checksum": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "pattern": "^[0-7]{4}$" }
      }
    },
    "artifactFileGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "items"],
      "properties": {
        "group": { "type": "string", "minLength": 1 },
        "targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactTarget" }
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifactFileItem" }
        }
      }
    },
    "artifactImageItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": { "type": "string", "minLength": 1 }
      }
    },
    "artifactImageGroup": {
      "description": "A grouped set of images to collect during prepare.",
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "items"],
      "properties": {
        "group": { "type": "string", "minLength": 1 },
        "targets": {
          "type": "array",
            "items": { "$ref": "#/$defs/artifactTarget" }
        },
        "backend": { "type": "object", "additionalProperties": true },
        "output": { "type": "object", "additionalProperties": true },
        "items": {
          "type": "array",
          "minItems": 1,
            "items": { "$ref": "#/$defs/artifactImageItem" }
        }
      }
    },
    "artifactPackageItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "artifactPackageGroup": {
      "description": "A grouped set of packages for one or more OS targets to collect during prepare.",
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "targets", "items"],
      "properties": {
        "group": { "type": "string", "minLength": 1 },
        "targets": {
          "type": "array",
          "minItems": 1,
            "items": { "$ref": "#/$defs/artifactTarget" }
        },
        "repo": { "type": "object", "additionalProperties": true },
        "backend": { "type": "object", "additionalProperties": true },
        "items": {
          "type": "array",
          "minItems": 1,
            "items": { "$ref": "#/$defs/artifactPackageItem" }
        }
      }
    },
    "artifacts": {
      "description": "Top-level artifact declaration model for files, images, and packages.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
            "items": { "$ref": "#/$defs/artifactFileGroup" }
        },
        "images": {
          "type": "array",
            "items": { "$ref": "#/$defs/artifactImageGroup" }
        },
        "packages": {
          "type": "array",
            "items": { "$ref": "#/$defs/artifactPackageGroup" }
        }
      }
    },
    "stepBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "spec"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,127}$"
        },
        "apiVersion": {
          "type": "string",
          "const": "deck/v1alpha1"
        },
        "kind": {
          "type": "string",
          "enum": [
            "CheckHost",
            "DownloadPackages",
            "DownloadImages",
            "DownloadFile",
            "InstallArtifacts",
            "InstallPackages",
            "EditFile",
            "CopyFile",
            "Sysctl",
            "Service",
            "EnsureDir",
            "Symlink",
            "InstallFile",
            "SystemdUnit",
            "RepoConfig",
            "PackageCache",
            "ContainerdConfig",
            "Swap",
            "KernelModule",
            "RunCommand",
            "WaitPath",
            "VerifyImages",
            "KubeadmInit",
            "KubeadmJoin",
            "KubeadmReset"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "when": {
          "type": "string",
          "minLength": 1
        },
        "retry": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "timeout": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$"
        },
        "register": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          }
        },
        "spec": {
          "type": "object"
        }
      }
    }
  }
}
