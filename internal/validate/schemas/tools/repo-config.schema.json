{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/repo-config.schema.json",
  "title": "RepoConfigStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "RepoConfig" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositories"],
      "properties": {
        "format": { "type": "string", "enum": ["auto", "apt", "yum"] },
        "path": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "pattern": "^[0-7]{4}$" },
        "replaceExisting": { "type": "boolean" },
        "disableExisting": { "type": "boolean" },
        "backupPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "cleanupPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "refreshCache": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "clean": { "type": "boolean" }
          }
        },
        "repositories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              {
                "type": "object",
                "additionalProperties": true,
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "name": { "type": "string" },
                  "baseurl": { "type": "string", "minLength": 1 },
                  "enabled": { "type": "boolean" },
                  "gpgcheck": { "type": "boolean" },
                  "gpgkey": { "type": "string" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["baseurl"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "type": { "type": "string", "enum": ["deb", "deb-src"] },
                  "baseurl": { "type": "string", "minLength": 1 },
                  "trusted": { "type": "boolean" },
                  "suite": { "type": "string", "minLength": 1 },
                  "component": { "type": "string", "minLength": 1 }
                }
              }
            ]
          }
        }
      }
    }
  }
}
