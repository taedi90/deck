{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/kubeadm.schema.json",
  "title": "KubeadmStep",
  "description": "Runs kubeadm operations through action-specific modes.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "kind": {
      "const": "Kubeadm"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "init",
            "join",
            "reset"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "stub",
            "real"
          ]
        },
        "configFile": {
          "type": "string"
        },
        "configTemplate": {
          "type": "string"
        },
        "pullImages": {
          "type": "boolean"
        },
        "outputJoinFile": {
          "type": "string"
        },
        "kubernetesVersion": {
          "type": "string"
        },
        "advertiseAddress": {
          "type": "string"
        },
        "podNetworkCIDR": {
          "type": "string"
        },
        "criSocket": {
          "type": "string"
        },
        "ignorePreflightErrors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skipIfAdminConfExists": {
          "type": "boolean",
          "default": true
        },
        "joinFile": {
          "type": "string"
        },
        "asControlPlane": {
          "type": "boolean",
          "default": false
        },
        "force": {
          "type": "boolean",
          "default": false
        },
        "ignoreErrors": {
          "type": "boolean",
          "default": false
        },
        "stopKubelet": {
          "type": "boolean",
          "default": true
        },
        "removePaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "removeFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cleanupContainers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "restartRuntimeService": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "init"
              }
            }
          },
          "then": {
            "required": [
              "outputJoinFile"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "join"
              }
            }
          },
          "then": {
            "required": [
              "joinFile"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "reset"
              }
            }
          },
          "then": {}
        }
      ]
    }
  }
}
