{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/package-cache.schema.json",
  "title": "PackageCacheStep",
  "description": "Refreshes package metadata and can restrict or exclude repos during refresh.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "kind": {
      "const": "PackageCache"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manager": {
          "type": "string",
          "enum": [
            "auto",
            "apt",
            "dnf"
          ]
        },
        "clean": {
          "type": "boolean"
        },
        "update": {
          "type": "boolean"
        },
        "restrictToRepos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excludeRepos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "anyOf": [
        {
          "properties": {
            "clean": {
              "const": true
            }
          },
          "required": [
            "clean"
          ]
        },
        {
          "properties": {
            "update": {
              "const": true
            }
          },
          "required": [
            "update"
          ]
        }
      ]
    }
  }
}
