{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/kubeadm-join.schema.json",
  "title": "KubeadmJoinStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "KubeadmJoin" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["joinFile"],
      "properties": {
        "mode": { "type": "string", "enum": ["stub", "real"] },
        "joinFile": { "type": "string" },
        "asControlPlane": { "type": "boolean", "default": false },
        "extraArgs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" }
      }
    }
  }
}
