{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/kernel-module.schema.json",
  "title": "KernelModuleStep",
  "description": "Loads and persists required kernel modules on the local node.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "kind": {
      "const": "KernelModule"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "name"
          ],
          "not": {
            "required": [
              "names"
            ]
          }
        },
        {
          "required": [
            "names"
          ],
          "not": {
            "required": [
              "name"
            ]
          }
        }
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "load": {
          "type": "boolean",
          "default": true
        },
        "persist": {
          "type": "boolean",
          "default": true
        },
        "persistFile": {
          "type": "string"
        }
      }
    }
  }
}
