{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/install-artifacts.schema.json",
  "title": "InstallArtifactsStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "InstallArtifacts" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts"],
      "properties": {
        "fetch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "offlineOnly": { "type": "boolean", "default": false },
            "strategy": { "type": "string", "enum": ["fallback"] },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type"],
                "anyOf": [
                  { "required": ["path"] },
                  { "required": ["url"] }
                ],
                "properties": {
                  "type": { "type": "string", "enum": ["local", "bundle", "repo", "online"] },
                  "path": { "type": "string", "minLength": 1 },
                  "url": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source"],
            "properties": {
              "source": {
                "type": "object",
                "additionalProperties": false,
                "required": ["amd64", "arm64"],
                "properties": {
                  "amd64": { "$ref": "#/$defs/artifactSource" },
                  "arm64": { "$ref": "#/$defs/artifactSource" }
                }
              },
              "skipIfPresent": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "executable": { "type": "boolean", "default": false }
                }
              },
              "install": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "mode": { "type": "string", "pattern": "^[0-7]{4}$" }
                }
              },
              "extract": {
                "type": "object",
                "additionalProperties": false,
                "required": ["destination"],
                "properties": {
                  "destination": { "type": "string", "minLength": 1 },
                  "include": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "mode": { "type": "string", "pattern": "^[0-7]{4}$" }
                }
              }
            },
            "oneOf": [
              { "required": ["install"] },
              { "required": ["extract"] }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "artifactSource": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["path"] },
        { "required": ["url"] }
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    }
  }
}
