{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/verify-images.schema.json",
  "title": "VerifyImagesStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "VerifyImages" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["images"],
      "properties": {
        "images": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" }
      }
    }
  }
}
