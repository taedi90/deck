{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/install-file.schema.json",
  "title": "InstallFileStep",
  "description": "Writes a file to the local node with content or templated content.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "kind": {
      "const": "InstallFile"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string"
        },
        "contentFromTemplate": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "pattern": "^[0-7]{4}$"
        }
      },
      "oneOf": [
        {
          "required": [
            "content"
          ]
        },
        {
          "required": [
            "contentFromTemplate"
          ]
        }
      ]
    }
  }
}
