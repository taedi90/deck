{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/kubeadm-reset.schema.json",
  "title": "KubeadmResetStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "KubeadmReset" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "force": { "type": "boolean", "default": false },
        "ignoreErrors": { "type": "boolean", "default": false },
        "stopKubelet": { "type": "boolean", "default": true },
        "criSocket": { "type": "string" },
        "removePaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "removeFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cleanupContainers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "restartRuntimeService": { "type": "string" },
        "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" }
      }
    }
  }
}
