{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/download-file.schema.json",
  "title": "DownloadFileStep",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "apiVersion", "kind", "spec"],
  "properties": {
    "id": { "type": "string" },
    "apiVersion": { "const": "deck/v1alpha1" },
    "kind": { "const": "DownloadFile" },
    "metadata": { "type": "object", "additionalProperties": true },
    "when": { "type": "string" },
    "retry": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
    "register": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string" }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "output"],
      "properties": {
        "source": {
          "type": "object",
          "additionalProperties": false,
          "anyOf": [
            { "required": ["url"] },
            { "required": ["path"] }
          ],
          "properties": {
            "url": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
          }
        },
        "fetch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "offlineOnly": { "type": "boolean", "default": false },
            "strategy": { "type": "string", "enum": ["fallback"] },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type"],
                "anyOf": [
                  { "required": ["path"] },
                  { "required": ["url"] }
                ],
                "properties": {
                  "type": { "type": "string", "enum": ["local", "bundle", "repo", "online"] },
                  "path": { "type": "string", "minLength": 1 },
                  "url": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": { "type": "string" },
            "chmod": { "type": "string", "pattern": "^[0-7]{4}$" }
          }
        }
      }
    }
  }
}
