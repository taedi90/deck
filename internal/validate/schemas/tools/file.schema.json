{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck.local/schemas/tools/file.schema.json",
  "title": "FileStep",
  "description": "Manages file operations through action-specific modes.",
  "x-deck-visibility": "public",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "when": {
      "type": "string"
    },
    "retry": {
      "type": "integer",
      "minimum": 0
    },
    "timeout": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    },
    "register": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "kind": {
      "const": "File"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "install",
            "copy",
            "edit"
          ]
        },
        "path": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "contentFromTemplate": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "pattern": "^[0-7]{4}$"
        },
        "src": {
          "type": "string"
        },
        "dest": {
          "type": "string"
        },
        "backup": {
          "type": "boolean"
        },
        "edits": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "match"
            ],
            "properties": {
              "match": {
                "type": "string"
              },
              "with": {
                "type": "string"
              },
              "op": {
                "type": "string"
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "install"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "path"
            ],
            "anyOf": [
              {
                "required": [
                  "content"
                ]
              },
              {
                "required": [
                  "contentFromTemplate"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "copy"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "src",
              "dest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "edit"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "path",
              "edits"
            ]
          }
        }
      ]
    }
  }
}
